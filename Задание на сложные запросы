-- БЛОК 8. Аналитика (29)
-- =====================================================

-- 29. Итоговый аналитический запрос
SELECT 
    c.full_name,
    COUNT(o.id) FILTER (WHERE o.status = 'paid') AS paid_orders_count,
    COALESCE(SUM(o.total_amount) FILTER (WHERE o.status = 'paid'), 0) AS total_paid_sum,
    COALESCE(AVG(o.total_amount) FILTER (WHERE o.status = 'paid'), 0) AS avg_paid_check
FROM clients c
LEFT JOIN orders o ON c.id = o.client_id
GROUP BY c.id, c.full_name
HAVING COALESCE(SUM(o.total_amount) FILTER (WHERE o.status = 'paid'), 0) > 5000
ORDER BY total_paid_sum DESC;
