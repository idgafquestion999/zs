-- =====================================================
-- DDL: Создание таблиц
-- =====================================================

DROP TABLE IF EXISTS bookings;
DROP TABLE IF EXISTS tours;
DROP TABLE IF EXISTS clients;
DROP TABLE IF EXISTS hotels;
DROP TABLE IF EXISTS countries;
DROP TABLE IF EXISTS tour_statuses;

CREATE TABLE countries (
    country_id SERIAL PRIMARY KEY,
    country_name VARCHAR(100) NOT NULL UNIQUE,
    continent VARCHAR(50) NOT NULL
);

CREATE TABLE hotels (
    hotel_id SERIAL PRIMARY KEY,
    hotel_name VARCHAR(150) NOT NULL,
    city VARCHAR(100) NOT NULL,
    country_id INTEGER NOT NULL,
    star_rating INTEGER CHECK (star_rating BETWEEN 1 AND 5),
    description TEXT,
    CONSTRAINT fk_hotels_country FOREIGN KEY (country_id) REFERENCES countries(country_id) ON DELETE RESTRICT
);

CREATE TABLE tour_statuses (
    status_id SERIAL PRIMARY KEY,
    status_name VARCHAR(30) NOT NULL UNIQUE
);

CREATE TABLE tours (
    tour_id SERIAL PRIMARY KEY,
    tour_name VARCHAR(200) NOT NULL,
    country_id INTEGER NOT NULL,
    hotel_id INTEGER NOT NULL,
    start_date DATE NOT NULL,
    end_date DATE NOT NULL,
    price NUMERIC(10,2) NOT NULL CHECK (price > 0),
    max_participants INTEGER NOT NULL CHECK (max_participants > 0),
    status_id INTEGER NOT NULL,
    description TEXT,
    CONSTRAINT fk_tours_country FOREIGN KEY (country_id) REFERENCES countries(country_id) ON DELETE RESTRICT,
    CONSTRAINT fk_tours_hotel FOREIGN KEY (hotel_id) REFERENCES hotels(hotel_id) ON DELETE RESTRICT,
    CONSTRAINT fk_tours_status FOREIGN KEY (status_id) REFERENCES tour_statuses(status_id) ON DELETE RESTRICT,
    CONSTRAINT check_dates CHECK (end_date > start_date)
);

CREATE TABLE clients (
    client_id SERIAL PRIMARY KEY,
    full_name VARCHAR(100) NOT NULL,
    passport_number VARCHAR(20) NOT NULL UNIQUE,
    phone VARCHAR(20),
    email VARCHAR(100) UNIQUE,
    registration_date DATE NOT NULL DEFAULT CURRENT_DATE
);

CREATE TABLE bookings (
    booking_id SERIAL PRIMARY KEY,
    tour_id INTEGER NOT NULL,
    client_id INTEGER NOT NULL,
    booking_date DATE NOT NULL DEFAULT CURRENT_DATE,
    participants_count INTEGER NOT NULL CHECK (participants_count > 0),
    total_price NUMERIC(10,2) NOT NULL CHECK (total_price >= 0),
    status VARCHAR(20) NOT NULL CHECK (status IN ('new', 'confirmed', 'paid', 'canceled')),
    CONSTRAINT fk_bookings_tour FOREIGN KEY (tour_id) REFERENCES tours(tour_id) ON DELETE CASCADE,
    CONSTRAINT fk_bookings_client FOREIGN KEY (client_id) REFERENCES clients(client_id) ON DELETE CASCADE
);

