-- =====================================================
-- DQL: Проверочные запросы
-- =====================================================

-- 1. Все туры с деталями
SELECT 
    t.tour_name,
    c.country_name,
    h.hotel_name,
    h.star_rating,
    t.start_date,
    t.end_date,
    t.price,
    ts.status_name AS tour_status
FROM tours t
JOIN countries c ON t.country_id = c.country_id
JOIN hotels h ON t.hotel_id = h.hotel_id
JOIN tour_statuses ts ON t.status_id = ts.status_id
ORDER BY t.start_date;

-- 2. Клиенты с суммой бронирований
SELECT 
    cl.full_name,
    COUNT(b.booking_id) AS bookings_count,
    SUM(b.total_price) AS total_spent
FROM clients cl
LEFT JOIN bookings b ON cl.client_id = b.client_id
GROUP BY cl.client_id, cl.full_name
ORDER BY total_spent DESC NULLS LAST;

-- 3. Самые популярные туры
SELECT 
    t.tour_name,
    c.country_name,
    COUNT(b.booking_id) AS bookings_count,
    SUM(b.participants_count) AS total_participants
FROM tours t
JOIN countries c ON t.country_id = c.country_id
LEFT JOIN bookings b ON t.tour_id = b.tour_id
GROUP BY t.tour_id, t.tour_name, c.country_name
ORDER BY bookings_count DESC;

-- 4. Оплаченные бронирования
SELECT 
    b.booking_id,
    cl.full_name AS client_name,
    t.tour_name,
    c.country_name,
    b.booking_date,
    b.participants_count,
    b.total_price,
    b.status
FROM bookings b
JOIN clients cl ON b.client_id = cl.client_id
JOIN tours t ON b.tour_id = t.tour_id
JOIN countries c ON t.country_id = c.country_id
WHERE b.status = 'paid'
ORDER BY b.booking_date DESC;
