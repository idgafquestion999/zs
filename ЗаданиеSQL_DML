-- ЭТАП 3: UPDATE
-- =====================================================

UPDATE books SET publication_year = 1867 WHERE title = 'Война и мир';

UPDATE books 
SET title = title || ' (классика)'
WHERE author_id = (SELECT author_id FROM authors WHERE author_name = 'Федор Достоевский');

-- Проверка: SELECT * FROM books;

-- =====================================================
-- ЭТАП 4: DELETE
-- =====================================================

DELETE FROM books WHERE title = 'Евгений Онегин';

DELETE FROM books WHERE publication_year < 1850;

-- Проверка: SELECT * FROM books;

-- =====================================================
-- ЭТАП 5: TRANSACTION
-- =====================================================

BEGIN;

INSERT INTO authors (author_name, birth_year) VALUES ('Л.Н. Толстой', 1828);

UPDATE books 
SET author_id = (SELECT author_id FROM authors WHERE author_name = 'Л.Н. Толстой')
WHERE author_id = (SELECT author_id FROM authors WHERE author_name = 'Лев Толстой');

DELETE FROM authors WHERE author_name = 'Лев Толстой';

COMMIT;

