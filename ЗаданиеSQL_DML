-- ИДЕНТИФИКАЦИЯ: Добавление себя
INSERT INTO authors (author_name, birth_year) VALUES ('Максим Иванников', 2000);

DO $$ 
DECLARE
    my_id INTEGER;
BEGIN
    SELECT author_id INTO my_id FROM authors WHERE author_name = 'Максим Иванников';
    INSERT INTO books (title, author_id, publication_year, genre) 
    VALUES ('Мастер и Маргарита', my_id, 1967, 'Роман');
END $$;

